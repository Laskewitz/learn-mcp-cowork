  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#2B579A",
  "developer": {
    "name": "Daniel Laskewitz",
    "websiteUrl": "https://github.com/Laskewitz/learn-mcp-cowork",
