  },
  "agentConnectors": [
    {
      "id": "microsoft-learn",
      "displayName": "Microsoft Learn MCP Server",
      "description": "Remote MCP server providing tools to search Microsoft Learn documentation and code samples.",
      "toolSource": {
        "remoteMcpServer": {
          "mcpServerUrl": "https://learn.microsoft.com/api/mcp",
          "mcpToolDescription": {
            "file": "./mcp-tool-description.md"
          },
          "authorization": {
            "type": "None"
